# Openrealm config template. Copy to `.env` (gitignored) and edit per machine.
# Nothing secret here yet (ports/URLs/origins), but the pattern is in place for when
# there is — NEVER put real secrets in Git. See DEPLOY.md for how each side uses these.

# ============ SERVER (read by server/index.ts via process.env) ============
# TCP port the authoritative WebSocket server listens on.
PORT=8080

# Bind address. 0.0.0.0 accepts external connections (needed on the VPS). Use 127.0.0.1
# only if a reverse proxy on the same box is the sole client.
HOST=0.0.0.0

# Snapshots broadcast per second (movement smoothness vs. bandwidth).
SNAPSHOT_HZ=10

# Seed for the shared world's deterministic sim (mob layout). Fixed -> the same world
# every boot. Optional; defaults to 1337.
# WORLD_SEED=1337

# Text chat tuning (optional). CHAT_MAX_LEN caps a message's length; CHAT_RATE_PER_SEC
# is the anti-flood limit (max messages per player per second). Defaults: 200 and 3.
# CHAT_MAX_LEN=200
# CHAT_RATE_PER_SEC=3

# Synchronized weather (optional). The server owns the day/night cycle + rain so all
# clients see the same sky. WEATHER_DAY_SECONDS = full cycle length. Rain is RANDOM but
# CAPPED: each shower lasts a random time in [RAIN_MIN, RAIN_MAX] and each dry spell a
# random time in [CLEAR_MIN, CLEAR_MAX]; rain fades in/out gradually over RAMP seconds.
# Defaults: day 240, shower 120–900s (≤15 min), dry 300–3600s (≤60 min), ramp 15.
# WEATHER_DAY_SECONDS=240
# WEATHER_RAIN_MIN_SECONDS=120
# WEATHER_RAIN_MAX_SECONDS=900
# WEATHER_CLEAR_MIN_SECONDS=300
# WEATHER_CLEAR_MAX_SECONDS=3600
# WEATHER_RAIN_RAMP_SECONDS=15

# Comma-separated list of allowed browser Origins (production allowlist).
#   - LEAVE EMPTY in local dev -> the server allows only localhost origins.
#   - SET in production to your client URL(s) -> only those browsers may connect.
# Example (production): ALLOWED_ORIGINS=https://meujogo.vercel.app
ALLOWED_ORIGINS=

# ============ CLIENT (read by Vite at build time; MUST be VITE_-prefixed) ============
# WebSocket URL the browser connects to in multiplayer mode. Supports ws:// and wss://.
#   - LOCAL DEV: leave it COMMENTED OUT -> the client falls back to ws://<current-host>:8080
#     (so opening the dev app via localhost OR a LAN IP both work).
#   - PRODUCTION (set in the Vercel dashboard, not here): wss://api.meujogo.com
# You can also override per tab with ?mp=ws://host:port (takes precedence over this).
# VITE_SERVER_URL=ws://localhost:8080
