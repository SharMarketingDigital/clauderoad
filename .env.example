# Openrealm config template. Copy to `.env` (which is gitignored) and edit.
# Nothing secret here yet (just ports/URLs), but the pattern is in place for when
# there is — never put secrets in code.

# --- server (read by server/index.ts via process.env) ---
PORT=8080          # WebSocket port the authoritative server listens on
SNAPSHOT_HZ=10     # snapshots broadcast per second (movement smoothness vs. bandwidth)

# --- client (read by Vite, must be VITE_-prefixed; optional) ---
# Where the browser connects in multiplayer mode. If unset, the client defaults to
# ws://<current-host>:8080. You can also override per-tab with ?mp=ws://host:port.
VITE_SERVER_URL=ws://localhost:8080
